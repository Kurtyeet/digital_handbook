{
    "name": "employee-leave-portal",
    "description": "Web-based Employee Leave Management Portal",
    "version": "1.0.0",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "EmployeeLeave\\": "includes/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "test-unit": "phpunit tests/unit/",
        "test-integration": "phpunit tests/integration/",
        "test-contract": "phpunit tests/contract/"
    },
    "config": {
        "optimize-autoloader": true
    }
}